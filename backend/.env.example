# Backend environment example
# Copy this file to backend/.env and fill your own values.

# Data backend: firebase (recommended) or fake
DATA_BACKEND=firebase

# Frontend origin used to build Stripe success/cancel URLs
FRONTEND_URL=http://localhost:5173

# Stripe secret key (NEVER commit a real sk_ key)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Optional: absolute or relative path to Firebase credentials JSON
# If omitted, backend uses backend/serviceAccountKey.json
# FIREBASE_CREDENTIALS=serviceAccountKey.json
